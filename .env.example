# ──────────────────────────────────────────────────────────────
# Hybrid RAG System — Environment Configuration
# Copy this to .env and update values before running
# ──────────────────────────────────────────────────────────────

# Application
ENVIRONMENT=production
SECRET_KEY=change-me-to-a-strong-random-secret-key-in-production
LOG_LEVEL=INFO

# LLM — Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=300

# Vector DB — Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents

# Search — Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=documents

# Database — PostgreSQL
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Cache — Redis
REDIS_URL=redis://redis:6379/0
REDIS_TTL=3600

# Embedding Model (runs inside backend container)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# Reranker
RERANKER_MODEL=BAAI/bge-reranker-large

# Document Storage (local disk)
DOCUMENTS_PATH=/app/data/documents

# Retrieval
HYBRID_BM25_WEIGHT=0.45
HYBRID_VECTOR_WEIGHT=0.55
RETRIEVAL_TOP_K=50
RERANKER_TOP_K=10

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64
